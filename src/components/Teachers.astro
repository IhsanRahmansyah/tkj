---
<section id="guru" class="teachers">
    <div class="container">
        <div class="section-title">
            <h2>Guru Produktif TKJ</h2>
            <p>Dibimbing langsung oleh tenaga pendidik profesional dan bersertifikasi di bidang IT dan Jaringan Komputer.</p>
        </div>

        <div class="teacher-grid">
            <!-- Teacher 1 -->
            <div class="teacher-card">
                <img src="https://images.unsplash.com/photo-1560250097-0b93528c311a?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80" alt="Guru">
                <div class="teacher-info">
                    <h4>Ahmad Rizki, S.Kom</h4>
                    <p>Kepala Program Studi TKJ</p>
                </div>
            </div>
            <!-- Teacher 2 -->
            <div class="teacher-card">
                <img src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80" alt="Guru">
                <div class="teacher-info">
                    <h4>Siti Nurbaya, M.T</h4>
                    <p>Guru Administrasi Server</p>
                </div>
            </div>
            <!-- Teacher 3 -->
            <div class="teacher-card">
                <img src="https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80" alt="Guru">
                <div class="teacher-info">
                    <h4>Budi Santoso, S.ST</h4>
                    <p>Guru Infrastruktur Jaringan</p>
                </div>
            </div>
            <!-- Teacher 4 -->
            <div class="teacher-card">
                <img src="https://images.unsplash.com/photo-1580820267682-426da823ed65?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80" alt="Guru">
                <div class="teacher-info">
                    <h4>Diana Fitriani, S.Kom</h4>
                    <p>Guru Komputer Jaringan Dasar</p>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .teachers {
        padding: 80px 0;
        background-color: var(--white);
    }

    .teacher-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
    }

    .teacher-card {
        position: relative;
        border-radius: 8px;
        overflow: hidden;
        height: 300px;
    }

    .teacher-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .teacher-info {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        padding: 20px 15px;
        background: linear-gradient(to top, rgba(11, 57, 105, 0.9), transparent);
        color: var(--white);
    }

    .teacher-info h4 {
        font-size: 1.1rem;
        margin-bottom: 2px;
        margin-top: 0;
    }

    .teacher-info p {
        font-size: 0.8rem;
        color: var(--secondary-color);
        margin: 0;
    }

    @media (max-width: 992px) {
        .teacher-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 768px) {
        .teacher-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
