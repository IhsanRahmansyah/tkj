---
const facilities = [
  {
    name: "Lab Jaringan Cisco",
    desc: "Dilengkapi dengan router dan switch Cisco standar sertifikasi CCNA.",
    image: "cisco-lab.jpg", // Will optimize later
  },
  {
    name: "Workshop Fiber Optic",
    desc: "Peralatan splicing dan OTDR untuk simulasi infrastruktur ISP modern.",
    image: "fo-lab.jpg",
  },
  {
    name: "Data Center Mini",
    desc: "Server rack untuk manajemen layanan berbasis awan dan virtualisasi.",
  },
];

const baseUrl = import.meta.env.BASE_URL;
const lab1 = `${baseUrl}lab1.jpg`;
const lab2 = `${baseUrl}lab2.jpg`;
const lab3 = `${baseUrl}lab3.jpg`;
---

<section id="fasilitas" class="section-padding bg-dim" style={`--lab1: url(${lab1}); --lab2: url(${lab2}); --lab3: url(${lab3});`}>
  <div class="container">
    <div class="grid-layout">
      <div class="text-content">
        <h2 class="gradient-text">Fasilitas Standar Dunia</h2>
        <p>
          Belajar dengan peralatan yang sama dengan yang digunakan oleh
          profesional di lapangan. Kami percaya pengalaman praktis adalah kunci
          keberhasilan.
        </p>

        <div class="features-list">
          <div class="feature">
            <strong>Mikrotik Academy</strong>
            <span
              >Pusat pelatihan resmi dengan kurikulum langsung dari Mikrotik.</span
            >
          </div>
          <div class="feature">
            <strong>Mikrotik Training Center</strong>
            <span>Sertifikasi internasional Mikrotik (MTCNA) terintegrasi.</span
            >
          </div>
        </div>
      </div>

      <div class="visual-content">
        {
          facilities.map((fac, i) => (
            <div class={`fac-card glass fac-${i}`}>
              <div class="fac-info">
                <h4>{fac.name}</h4>
                <p>{fac.desc}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .bg-dim {
    background: linear-gradient(to bottom, var(--bg-dark), var(--bg-surface));
  }

  .grid-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  h2 {
    font-size: 3.5rem;
    margin-bottom: 1.5rem;
  }

  .text-content p {
    font-size: 1.2rem;
    color: var(--text-muted);
    margin-bottom: 3rem;
  }

  .features-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .feature {
    padding-left: 2rem;
    border-left: 2px solid var(--primary);
  }

  .feature strong {
    display: block;
    font-size: 1.3rem;
    color: #fff;
    margin-bottom: 0.5rem;
  }

  .feature span {
    color: var(--text-dim);
  }

  .visual-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .fac-card {
    height: 300px;
    border-radius: 20px;
    display: flex;
    align-items: flex-end;
    padding: 2rem;
    background-size: cover;
    background-position: center;
    transition: transform 0.5s var(--transition-smooth);
  }

  .fac-0 {
    grid-column: span 2;
    background-image: linear-gradient(to top, rgba(0, 0, 0, 0.8), transparent),
      var(--lab1);
  }
  .fac-1 {
    background-image: linear-gradient(to top, rgba(0, 0, 0, 0.8), transparent),
      var(--lab2);
  }
  .fac-2 {
    background-image: linear-gradient(to top, rgba(0, 0, 0, 0.8), transparent),
      var(--lab3);
  }

  .fac-card:hover {
    transform: scale(1.02);
  }

  h4 {
    font-size: 1.4rem;
    margin-bottom: 0.5rem;
  }
  .fac-info p {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  @media (max-width: 968px) {
    .grid-layout {
      grid-template-columns: 1fr;
    }
    .visual-content {
      order: -1;
    }
  }
</style>
