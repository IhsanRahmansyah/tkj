<div class="topbar">
    <div class="container">
        <div class="topbar-left">
            <span><i class="fa-solid fa-phone"></i> (021) 880-XXXX</span>
            <span><i class="fa-solid fa-envelope"></i> info.tkj@smkkg2bekasi.sch.id</span>
        </div>
        <div class="topbar-right">
            <span>Ikuti Kami:</span>
            <div class="social-icons">
                <a href="#" aria-label="Facebook"><i class="fa-brands fa-facebook-f"></i></a>
                <a href="#" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
                <a href="#" aria-label="YouTube"><i class="fa-brands fa-youtube"></i></a>
            </div>
        </div>
    </div>
</div>

<style>
    .topbar {
        background-color: #062342;
        color: var(--white);
        font-size: 0.85rem;
        padding: 8px 0;
    }

    .topbar .container {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .topbar-left span {
        margin-right: 15px;
    }
    
    .topbar-left i {
        margin-right: 5px;
        color: var(--secondary-color);
    }

    .topbar-right {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .social-icons a {
        color: var(--white);
        margin-left: 10px;
        transition: var(--transition);
    }

    .social-icons a:hover {
        color: var(--secondary-color);
    }

    @media (max-width: 768px) {
        .topbar {
            display: none;
        }
    }
</style>
