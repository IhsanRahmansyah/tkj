---
const year = new Date().getFullYear();
---

<footer>
    <div class="container">
        <div class="footer-grid">
            <div class="footer-col">
                <div class="logo footer-logo">
                    <i
                        class="fa-solid fa-network-wired"
                        style="font-size: 1.5rem; color: var(--secondary-color);"
                    ></i>
                    <h2
                        style="font-size: 1.2rem; color: var(--white); margin: 0;"
                    >
                        SMK Karya Guna 2
                    </h2>
                </div>
                <p class="footer-about">
                    Mencetak lulusan yang unggul, mandiri, berbudaya, dan siap
                    bersaing di dunia industri teknologi informasi khususnya di
                    bidang Teknik Komputer dan Jaringan.
                </p>
                <div class="social-icons">
                    <a href="#" aria-label="Facebook"
                        ><i class="fa-brands fa-facebook-f"></i></a
                    >
                    <a href="#" aria-label="Instagram"
                        ><i class="fa-brands fa-instagram"></i></a
                    >
                    <a href="#" aria-label="YouTube"
                        ><i class="fa-brands fa-youtube"></i></a
                    >
                    <a href="#" aria-label="TikTok"
                        ><i class="fa-brands fa-tiktok"></i></a
                    >
                </div>
            </div>

            <div class="footer-col">
                <h3 class="footer-heading">Navigasi</h3>
                <ul class="footer-links">
                    <li><a href="#">Beranda Utama</a></li>
                    <li><a href="#">Profil Jurusan TKJ</a></li>
                    <li><a href="#">Fasilitas Lab</a></li>
                    <li><a href="#">Galeri Kegiatan</a></li>
                    <li><a href="#">Berita & Artikel</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <h3 class="footer-heading">Tautan Terkait</h3>
                <ul class="footer-links">
                    <li>
                        <a href="https://smkkg2.sch.id/spmb/"
                            >Portal PPDB Online</a
                        >
                    </li>
                    <li><a href="#">E-Learning Siswa</a></li>
                    <li><a href="#">Info Lowongan (BKK)</a></li>
                    <li><a href="#">Alumni TKJ</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <h3 class="footer-heading">Kontak Info</h3>
                <ul class="footer-contact">
                    <li>
                        <i class="fa-solid fa-location-dot"></i>
                        <span
                            >Jl. Karang Satria No.XX, Duren Jaya, Bekasi Timur,
                            Kota Bekasi, Jawa Barat.</span
                        >
                    </li>
                    <li>
                        <i class="fa-solid fa-phone"></i>
                        <span>(021) 880-XXXX</span>
                    </li>
                    <li>
                        <i class="fa-solid fa-envelope"></i>
                        <span>info@smkkg2bekasi.sch.id</span>
                    </li>
                </ul>
            </div>
        </div>

        <div class="footer-bottom">
            <p>
                &copy; {year} Jurusan TKJ SMK Karya Guna 2 Bekasi. All Rights Reserved.
                Designed for Educational Purpose.
            </p>
        </div>
    </div>
</footer>

<style>
    footer {
        background-color: #062342;
        color: var(--white);
        padding: 60px 0 20px;
    }

    .footer-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 40px;
    }

    .footer-logo {
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .footer-about {
        font-size: 0.9rem;
        color: #cbd5e1;
        margin-bottom: 20px;
    }

    .social-icons {
        display: flex;
        gap: 15px;
    }

    .social-icons a {
        color: var(--white);
        font-size: 1.1rem;
        transition: var(--transition);
    }

    .social-icons a:hover {
        color: var(--secondary-color);
    }

    .footer-heading {
        font-size: 1.1rem;
        color: var(--secondary-color);
        margin-bottom: 20px;
        position: relative;
        padding-bottom: 10px;
        margin-top: 0;
    }

    .footer-heading::after {
        content: "";
        position: absolute;
        left: 0;
        bottom: 0;
        width: 40px;
        height: 2px;
        background-color: var(--secondary-color);
    }

    .footer-links {
        padding: 0;
        margin: 0;
        list-style: none;
    }

    .footer-links li {
        margin-bottom: 10px;
    }

    .footer-links a {
        color: #cbd5e1;
        font-size: 0.9rem;
        transition: var(--transition);
    }

    .footer-links a:hover {
        color: var(--secondary-color);
        padding-left: 5px;
    }

    .footer-contact {
        padding: 0;
        margin: 0;
        list-style: none;
    }

    .footer-contact li {
        display: flex;
        gap: 10px;
        margin-bottom: 15px;
        font-size: 0.9rem;
        color: #cbd5e1;
    }

    .footer-contact i {
        color: var(--secondary-color);
        margin-top: 4px;
    }

    .footer-bottom {
        text-align: center;
        padding-top: 20px;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        font-size: 0.85rem;
        color: #94a3b8;
    }

    @media (max-width: 992px) {
        .footer-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 768px) {
        .footer-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
