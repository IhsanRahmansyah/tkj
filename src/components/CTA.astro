<section class="cta">
    <div class="container cta-container">
        <div class="cta-text">
            <h2>Siap Menjadi Pakar Jaringan Masa Depan?</h2>
            <p>Kuota pendaftaran terbatas! Segera daftarkan dirimu ke jurusan TKJ SMK Karya Guna 2 Bekasi sekarang juga.</p>
        </div>
        <div class="cta-btn">
            <a href="#" class="btn btn-primary cta-action">Daftar Online PPDB <i class="fa-solid fa-paper-plane"></i></a>
        </div>
    </div>
</section>

<style>
    .cta {
        background-color: var(--primary-color);
        padding: 50px 0;
        color: var(--white);
    }

    .cta-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .cta-text h2 {
        font-size: 2rem;
        margin-bottom: 10px;
        margin-top: 0;
    }

    .cta-text p {
        font-size: 1rem;
        opacity: 0.9;
        margin: 0;
    }

    .cta-action {
        font-size: 1.1rem;
        padding: 15px 30px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    @media (max-width: 768px) {
        .cta-container {
            flex-direction: column;
            text-align: center;
            gap: 20px;
        }
    }
</style>
