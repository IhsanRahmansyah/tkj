---
import Layout from './Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	description?: string;
}

const { title, description } = Astro.props;
---

<Layout title={title} description={description}>
	<Navigation />
	<main class="content-page">
		<div class="container container-narrow">
			<header class="page-header">
				<h1 class="gradient-headline">{title}</h1>
			</header>
			<div class="prose">
				<slot />
			</div>
		</div>
	</main>
	<Footer />
</Layout>

<style>
	.content-page {
		padding: 10rem 0 8rem;
	}

	.container-narrow {
		max-width: 800px;
	}

	.page-header {
		margin-bottom: 4rem;
		text-align: center;
	}

	h1 {
		font-size: 3.5rem;
		line-height: 1.2;
	}

	.gradient-headline {
		background: linear-gradient(to right, var(--color-header) 20%, var(--color-primary) 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.prose {
		color: var(--color-body);
		line-height: 1.8;
		font-size: 1.1rem;
	}

	.prose :global(h2) {
		margin-top: 3rem;
		margin-bottom: 1.5rem;
		color: var(--color-header);
		font-size: 1.8rem;
	}

	.prose :global(p) {
		margin-bottom: 1.5rem;
	}

	.prose :global(ul) {
		margin-bottom: 1.5rem;
		padding-left: 1.5rem;
	}

	.prose :global(li) {
		margin-bottom: 0.5rem;
	}
</style>
