---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);
---

<Layout title={post.data.title} description={post.data.description}>
	<Navigation />
	
	<article class="single-post section-padding">
		<div class="container container-small">
			<header class="post-header">
				<div class="post-meta">
					<time datetime={post.data.pubDate.toISOString()}>
						{post.data.pubDate.toLocaleDateString('id-ID', {
							year: 'numeric',
							month: 'long',
							day: 'numeric',
						})}
					</time>
					<span class="separator">•</span>
					<span class="author">{post.data.author}</span>
				</div>
				<h1 class="gradient-text">{post.data.title}</h1>
				
				{post.data.heroImage && (
					<div class="hero-image glass">
						<img src={post.data.heroImage} alt={post.data.title} />
					</div>
				)}
			</header>

			<div class="post-content prose">
				<Content />
			</div>

			<footer class="post-footer">
				<div class="tags">
					{post.data.tags.map(tag => <span class="tag">#{tag}</span>)}
				</div>
				<div class="share">
					<p>Bagikan artikel ini:</p>
					<!-- Social share links placeholder -->
					<div class="share-links">
						<a href="#">FB</a>
						<a href="#">TW</a>
						<a href="#">WA</a>
					</div>
				</div>
			</footer>
			
			<div class="back-link">
				<a href={`${import.meta.env.BASE_URL}blog`}>← Kembali ke Blog</a>
			</div>
		</div>
	</article>

	<Footer />
</Layout>

<style>
	.single-post {
		padding-top: 10rem;
	}

	.container-small {
		max-width: 800px;
	}

	.post-header {
		text-align: center;
		margin-bottom: 4rem;
	}

	.post-meta {
		color: var(--color-muted);
		font-size: 0.9rem;
		margin-bottom: 1.5rem;
		display: flex;
		justify-content: center;
		gap: 0.5rem;
	}

	h1 {
		font-size: clamp(2rem, 5vw, 3.5rem);
		line-height: 1.2;
		margin-bottom: 3rem;
		color: var(--color-header);
	}

	.hero-image {
		margin-top: 2rem;
		border-radius: 24px;
		overflow: hidden;
		max-height: 500px;
		border: 1px solid var(--color-gray-light);
	}

	.hero-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.post-content {
		color: var(--color-body);
		line-height: 1.8;
		font-size: 1.15rem;
	}

	/* Simple prose styling */
	.prose :global(h2), .prose :global(h3) {
		margin-top: 3rem;
		margin-bottom: 1.5rem;
		color: var(--color-header);
	}

	.prose :global(p) {
		margin-bottom: 1.5rem;
	}

	.prose :global(blockquote) {
		border-left: 4px solid var(--color-primary);
		padding-left: 1.5rem;
		font-style: italic;
		color: var(--color-muted);
		margin: 2.5rem 0;
	}

	.post-footer {
		margin-top: 5rem;
		padding-top: 3rem;
		border-top: 1px solid var(--color-gray-light);
	}

	.tags {
		display: flex;
		gap: 0.8rem;
		margin-bottom: 3rem;
	}

	.tag {
		color: var(--color-primary);
		font-size: 0.9rem;
		font-weight: 500;
	}

	.share {
		text-align: center;
		background: var(--color-gray-light);
		padding: 2rem;
		border-radius: 16px;
	}

	.share p {
		margin-bottom: 1rem;
		font-size: 0.9rem;
		color: var(--color-muted);
	}

	.gradient-text {
		background: linear-gradient(to right, var(--color-header) 20%, var(--color-primary) 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.share-links {
		display: flex;
		justify-content: center;
		gap: 2rem;
	}

	.back-link {
		margin-top: 4rem;
		text-align: center;
	}

	.back-link a {
		color: var(--primary);
		font-weight: 500;
	}
</style>
