---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
	const allPosts = await getCollection('blog');
	const posts = allPosts.filter(post => !post.data.tags.includes('Pengumuman'));
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);

// Construct JSON-LD Schema
const baseUrl = Astro.site ? Astro.site.href : 'https://smkkg2.sch.id';
const articleUrl = new URL(Astro.url.pathname, baseUrl).href;
const heroImageUrl = post.data.heroImage 
    ? new URL(`${import.meta.env.BASE_URL}${post.data.heroImage.startsWith('/') ? post.data.heroImage.slice(1) : post.data.heroImage}`, baseUrl).href
    : new URL(`${import.meta.env.BASE_URL}og-image.jpg`, baseUrl).href;

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "image": [heroImageUrl],
  "datePublished": post.data.pubDate.toISOString(),
  "author": [{
      "@type": "Person",
      "name": post.data.author,
      "url": articleUrl
    }],
  "publisher": {
    "@type": "Organization",
    "name": "SMK Karya Guna 2 Bekasi",
    "logo": {
      "@type": "ImageObject",
      "url": new URL(`${import.meta.env.BASE_URL}logo.svg`, baseUrl).href
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": articleUrl
  }
});
---

<Layout title={post.data.title} description={post.data.description}>
	<!-- Inject Schema Markup -->
	<script type="application/ld+json" set:html={schema} />
	
	<Navigation />
	
	<article class="single-post section-padding">
		<div class="container container-small">
			<header class="post-header">
				<nav aria-label="breadcrumb" class="breadcrumb">
					<a href={`${import.meta.env.BASE_URL}`}>Beranda</a>
					<span class="separator">/</span>
					<a href={`${import.meta.env.BASE_URL}blog`}>Blog & Berita</a>
					<span class="separator">/</span>
					<span class="current" aria-current="page">{post.data.title}</span>
				</nav>
				
				<div class="post-meta">
					<time datetime={post.data.pubDate.toISOString()}>
						{post.data.pubDate.toLocaleDateString('id-ID', {
							year: 'numeric',
							month: 'long',
							day: 'numeric',
						})}
					</time>
					<span class="separator">•</span>
					<span class="author">{post.data.author}</span>
				</div>
				<h1>{post.data.title}</h1>
				
				{post.data.heroImage && (
					<div class="hero-image glass">
						<img src={`${import.meta.env.BASE_URL}${post.data.heroImage.startsWith('/') ? post.data.heroImage.slice(1) : post.data.heroImage}`} alt={post.data.title} />
					</div>
				)}
			</header>

			<div class="post-content prose">
				<Content />
			</div>

			<footer class="post-footer">
				<div class="tags">
					{post.data.tags.map(tag => <span class="tag">#{tag}</span>)}
				</div>
				<div class="share">
					<p>Bagikan artikel ini:</p>
					<!-- Social share links placeholder -->
					<div class="share-links">
						<a href="#">FB</a>
						<a href="#">TW</a>
						<a href="#">WA</a>
					</div>
				</div>
			</footer>
			
			<div class="back-link">
				<a href={`${import.meta.env.BASE_URL}blog`}>← Kembali ke Blog</a>
			</div>
		</div>
	</article>

	<Footer />
</Layout>

<style>
	.single-post {
		padding-top: 4rem;
	}

	.container-small {
		max-width: 800px;
	}

	.post-header {
		text-align: center;
		margin-bottom: 2.5rem;
	}

	.breadcrumb {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.85rem;
		color: var(--color-muted);
		margin-bottom: 1.5rem;
		flex-wrap: wrap;
	}

	.breadcrumb a {
		color: var(--color-primary);
		transition: var(--transition);
	}

	.breadcrumb a:hover {
		text-decoration: underline;
	}

	.breadcrumb .current {
		color: var(--color-body);
		max-width: 250px;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.post-meta {
		color: var(--color-muted);
		font-size: 0.9rem;
		margin-bottom: 1rem;
		display: flex;
		justify-content: center;
		gap: 0.5rem;
	}

	h1 {
		font-size: clamp(2rem, 5vw, 3.5rem);
		line-height: 1.2;
		margin-bottom: 1.5rem;
		color: var(--color-header);
	}

	.hero-image {
		margin-top: 1rem;
		border-radius: 24px;
		overflow: hidden;
		max-height: 500px;
		border: 1px solid var(--color-gray-light);
	}

	.hero-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.post-content {
		color: var(--color-body);
		line-height: 1.8;
		font-size: 1.15rem;
	}

	/* Simple prose styling */
	.prose :global(h2), .prose :global(h3) {
		margin-top: 3rem;
		margin-bottom: 1.5rem;
		color: var(--color-header);
	}

	.prose :global(p) {
		margin-bottom: 1.5rem;
	}

	.prose :global(blockquote) {
		border-left: 4px solid var(--color-primary);
		padding-left: 1.5rem;
		font-style: italic;
		color: var(--color-muted);
		margin: 2.5rem 0;
	}

	.prose :global(table) {
		width: 100%;
		border-collapse: collapse;
		margin: 2rem 0;
	}

	.prose :global(th), .prose :global(td) {
		border: 1px solid var(--border-color, #ccc);
		padding: 0.75rem 1rem;
		text-align: left;
	}

	.prose :global(th) {
		background-color: var(--bg-light, #f3f4f6);
		font-weight: 600;
	}

	.prose :global(a) {
		color: #0b3969; /* var(--primary-color) from global */
		text-decoration: none;
		font-weight: 500;
		border-bottom: 1px dashed #0b3969;
		transition: all 0.2s ease;
	}

	.prose :global(a:hover) {
		color: #fca311; /* var(--secondary-color) */
		border-bottom: 1px solid #fca311;
	}

	.post-footer {
		margin-top: 5rem;
		padding-top: 3rem;
		border-top: 1px solid var(--color-gray-light);
	}

	.tags {
		display: flex;
		gap: 0.8rem;
		margin-bottom: 3rem;
	}

	.tag {
		color: var(--color-primary);
		font-size: 0.9rem;
		font-weight: 500;
	}

	.share {
		text-align: center;
		background: var(--color-gray-light);
		padding: 2rem;
		border-radius: 16px;
	}

	.share p {
		margin-bottom: 1rem;
		font-size: 0.9rem;
		color: var(--color-muted);
	}

	.share-links {
		display: flex;
		justify-content: center;
		gap: 2rem;
	}

	.back-link {
		margin-top: 4rem;
		text-align: center;
	}

	.back-link a {
		color: var(--primary);
		font-weight: 500;
	}
</style>
