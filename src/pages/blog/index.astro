---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Blog & Berita - TKJ SMK Karya Guna 2 Bekasi" description="Kumpulan berita, artikel teknologi, dan update terbaru dari jurusan TKJ SMK Karya Guna 2 Bekasi.">
	<Navigation />
	
	<main class="blog-archive section-padding">
		<div class="container">
			<header class="archive-header">
				<h1 class="gradient-text">Blog & Berita</h1>
				<p>Update terbaru mengenai teknologi, kegiatan jurusan, dan prestasi siswa.</p>
			</header>

			<div class="posts-grid">
				{posts.map((post) => (
					<article class="post-card glass">
						{post.data.heroImage && (
							<div class="post-image" style={`background-image: url(${import.meta.env.BASE_URL}${post.data.heroImage.startsWith('/') ? post.data.heroImage.slice(1) : post.data.heroImage})`}></div>
						)}
						<div class="post-content">
							<div class="meta">
								<span class="date">{post.data.pubDate.toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
								<span class="author">{post.data.author}</span>
							</div>
							<h2><a href={`${import.meta.env.BASE_URL}blog/${post.id}/`}>{post.data.title}</a></h2>
							<p>{post.data.description}</p>
							<div class="tags">
								{post.data.tags.map(tag => <span class="tag">{tag}</span>)}
							</div>
						</div>
					</article>
				))}
			</div>
		</div>
	</main>

	<Footer />
</Layout>

<style>
	.blog-archive {
		padding-top: 10rem;
	}

	.archive-header {
		text-align: center;
		margin-bottom: 5rem;
	}

	.archive-header h1 {
		font-size: 4rem;
		margin-bottom: 1rem;
		color: var(--color-header);
	}

	.archive-header p {
		color: var(--color-body);
		font-size: 1.2rem;
	}

	.posts-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
		gap: 2.5rem;
	}

	.post-card {
		border-radius: 20px;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		height: 100%;
		transition: transform 0.3s ease;
		background: #fff;
		border: 1px solid var(--color-gray-light);
	}

	.post-card:hover {
		transform: translateY(-5px);
		border-color: var(--color-primary);
		box-shadow: 0 10px 30px rgba(0,0,0,0.05);
	}

	.post-image {
		height: 220px;
		background-size: cover;
		background-position: center;
		background-color: var(--color-gray-light);
	}

	.post-content {
		padding: 2rem;
		flex-grow: 1;
		display: flex;
		flex-direction: column;
	}

	.meta {
		display: flex;
		gap: 1rem;
		font-size: 0.85rem;
		color: var(--color-muted);
		margin-bottom: 1rem;
	}

	.post-content h2 {
		font-size: 1.5rem;
		margin-bottom: 1rem;
		line-height: 1.3;
		color: var(--color-header);
	}

	.post-content h2 a:hover {
		color: var(--color-primary);
	}

	.post-content p {
		color: var(--color-body);
		font-size: 1rem;
		margin-bottom: 2rem;
		flex-grow: 1;
	}

	.tags {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.tag {
		padding: 0.2rem 0.8rem;
		background: var(--color-gray-light);
		border-radius: 4px;
		font-size: 0.75rem;
		color: var(--color-muted);
	}

	.gradient-text {
		background: linear-gradient(to right, var(--color-header) 20%, var(--color-primary) 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	@media (max-width: 768px) {
		.archive-header h1 { font-size: 3rem; }
	}
</style>
