---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
	const allPosts = await getCollection('blog');
	const posts = allPosts.filter(post => post.data.tags.includes('Pengumuman'));
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);

// Construct JSON-LD Schema
const baseUrl = Astro.site ? Astro.site.href : 'https://smkkg2.sch.id';
const articleUrl = new URL(Astro.url.pathname, baseUrl).href;

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.pubDate.toISOString(),
  "author": [{
      "@type": "Person",
      "name": post.data.author,
      "url": articleUrl
    }],
  "publisher": {
    "@type": "Organization",
    "name": "SMK Karya Guna 2 Bekasi",
    "logo": {
      "@type": "ImageObject",
      "url": new URL(`${import.meta.env.BASE_URL}logo.svg`, baseUrl).href
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": articleUrl
  }
});
---

<Layout title={post.data.title} description={post.data.description}>
	<!-- Inject Schema Markup -->
	<script type="application/ld+json" set:html={schema} />
	
	<Navigation />
	
	<article class="single-post section-padding">
		<div class="container container-small">
			<header class="post-header">
				<nav aria-label="breadcrumb" class="breadcrumb">
					<a href={`${import.meta.env.BASE_URL}`}>Beranda</a>
					<span class="separator">/</span>
					<a href={`${import.meta.env.BASE_URL}pengumuman`}>Pengumuman</a>
					<span class="separator">/</span>
					<span class="current" aria-current="page">{post.data.title}</span>
				</nav>

				<div class="post-meta">
					<time datetime={post.data.pubDate.toISOString()}>
						{post.data.pubDate.toLocaleDateString('id-ID', {
							year: 'numeric',
							month: 'long',
							day: 'numeric',
						})}
					</time>
					<span class="separator">•</span>
					<span class="author">{post.data.author}</span>
				</div>
				<h1>{post.data.title}</h1>
			</header>

			<div class="post-content prose">
				<Content />
			</div>

			<footer class="post-footer">
				<div class="share">
					<p>Bagikan pengumuman ini:</p>
					<!-- Social share links placeholder -->
					<div class="share-links">
						<a href="#">FB</a>
						<a href="#">TW</a>
						<a href="#">WA</a>
					</div>
				</div>
			</footer>
			
			<div class="back-link">
				<a href={`${import.meta.env.BASE_URL}pengumuman`}>← Kembali ke Pengumuman</a>
			</div>
		</div>
	</article>

	<Footer />
</Layout>

<style>
	.single-post {
		padding-top: 4rem;
	}

	.container-small {
		max-width: 800px;
	}

	.post-header {
		text-align: center;
		margin-bottom: 2.5rem;
	}

	.breadcrumb {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.85rem;
		color: var(--color-muted);
		margin-bottom: 1.5rem;
		flex-wrap: wrap;
	}

	.breadcrumb a {
		color: var(--color-primary);
		transition: var(--transition);
	}

	.breadcrumb a:hover {
		text-decoration: underline;
	}

	.breadcrumb .current {
		color: var(--color-body);
		max-width: 250px;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.post-meta {
		color: var(--color-muted);
		font-size: 0.9rem;
		margin-bottom: 1.5rem;
		display: flex;
		justify-content: center;
		gap: 0.5rem;
	}

	h1 {
		font-size: clamp(2rem, 5vw, 3.5rem);
		line-height: 1.2;
		margin-bottom: 1.5rem;
		color: var(--color-header);
	}

	.post-content {
		color: var(--color-body);
		line-height: 1.8;
		font-size: 1.15rem;
	}

	/* Simple prose styling */
	.prose :global(h2), .prose :global(h3) {
		margin-top: 3rem;
		margin-bottom: 1.5rem;
		color: var(--color-header);
	}

	.prose :global(p) {
		margin-bottom: 1.5rem;
	}

	.post-footer {
		margin-top: 5rem;
		padding-top: 3rem;
		border-top: 1px solid var(--color-gray-light);
	}

	.share {
		text-align: center;
		background: var(--color-gray-light);
		padding: 2rem;
		border-radius: 16px;
	}

	.share p {
		margin-bottom: 1rem;
		font-size: 0.9rem;
		color: var(--color-muted);
	}

	.share-links {
		display: flex;
		justify-content: center;
		gap: 2rem;
	}

	.back-link {
		margin-top: 4rem;
		text-align: center;
	}

	.back-link a {
		color: var(--primary);
		font-weight: 500;
	}
</style>
